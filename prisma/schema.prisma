generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
}

model User {
  id       Int    @id @default(autoincrement())
  fullName String
  email    String @unique

  password          String?
  whatsappNumber    String
  role              UserRole @default(CUSTOMER)
  verificationToken String?  @unique
  isVerified        Boolean? @default(false)

  googleId     String? @unique
  googleAvatar String?
  googleToken  String?

  @@map("users")
}

model AreaType {
  id                 Int     @id @default(autoincrement())
  uuid               String  @unique @default(uuid())
  areaName           String
  maxCapPax          Int
  electricPowerWatt  Int
  isWeddingAvailable Boolean

  areaPricePlans AreaPricePlan[]

  @@map("area_types")
}

model AreaPricePlan {
  id           Int    @id @default(autoincrement())
  areaTypeId   Int
  planName     String
  planDuration Int
  planPrice    Float

  areaType AreaType @relation(fields: [areaTypeId], references: [id])

  @@map("area_price_plans")
}
