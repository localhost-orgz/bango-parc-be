generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum ReservationStatus {
  WAITING_DP
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
  EXPIRED
}

// enum PaymentScheduleStatus {
//   PENDING
//   PARTIAL
//   PAID
//   OVERDUE
//   CANCELLED
// }

// enum PaymentProofApprovalStatus {
//   PENDING
//   APPROVED
//   REJECTED
//   CANCELLED
// }

enum MediaType {
  IMAGE
  TOUR360
}

model User {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  fullName String
  email    String @unique

  password       String?
  whatsappNumber String

  role UserRole @default(CUSTOMER)

  verificationToken String?  @unique
  isVerified        Boolean? @default(false)

  googleId     String? @unique
  googleAvatar String?
  googleToken  String?

  customerReservations Reservation[] @relation("CustomerReservations")
  // adminApprovedProofs  PaymentProof[] @relation("AdminApprovedProofs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ReservationType {
  id Int @id @default(autoincrement())

  name                 String
  durationIntervalHour Int

  reservations Reservation[]
  areaPrices   AreaPrice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reservation_types")
}

model Area {
  id Int @id @default(autoincrement())

  name        String
  description String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  areaFacilities AreaFacility[]

  galleries        Gallery[]
  areaPrices       AreaPrice[]
  // areaReservations AreaReservation[]
  areaReservations AreaReservation[]

  @@map("areas")
}

model Facility {
  id        Int     @id @default(autoincrement())
  name      String
  icon      String
  value     String
  isDisplay Boolean @default(true)

  areaFacilities AreaFacility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("facilities")
}

model AreaFacility {
  id         Int @id @default(autoincrement())
  areaId     Int
  facilityId Int

  area     Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([areaId, facilityId])
  @@map("area_facilities")
}

model Gallery {
  id Int @id @default(autoincrement())

  areaId Int
  area   Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  title       String
  description String?

  filePath  String
  mediaType MediaType

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("galleries")
}

model AreaPrice {
  id Int @id @default(autoincrement())

  areaId Int
  area   Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  reservationTypeId Int
  reservationType   ReservationType @relation(fields: [reservationTypeId], references: [id], onDelete: Cascade)

  price Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([areaId, reservationTypeId])
  @@map("area_prices")
}

model Addon {
  id Int @id @default(autoincrement())

  name        String
  price       Decimal @db.Decimal(15, 2)
  description String?

  isActive Boolean @default(true)

  addonReservations AddonReservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addons")
}

model Reservation {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  bookingCode String @unique

  customerId Int
  customer   User @relation("CustomerReservations", fields: [customerId], references: [id])

  reservationTypeId Int
  reservationType   ReservationType @relation(fields: [reservationTypeId], references: [id])

  startDateTime DateTime
  endDateTime   DateTime

  totalAreaPrice  Decimal @default(0) @db.Decimal(15, 2)
  totalAddonPrice Decimal @default(0) @db.Decimal(15, 2)

  totalPrice       Decimal @default(0) @db.Decimal(15, 2)
  paidAmount       Decimal @default(0) @db.Decimal(15, 2)
  remainingBalance Decimal @default(0) @db.Decimal(15, 2)

  status ReservationStatus @default(WAITING_DP)

  cancellationReason String?
  cancelledAt        DateTime?

  areaReservations  AreaReservation[]
  addonReservations AddonReservation[]

  // paymentSchedules PaymentSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reservations")
}

model AreaReservation {
  id Int @id @default(autoincrement())

  reservationId Int
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  areaId Int
  area   Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  priceSnapshot Decimal @db.Decimal(15, 2)
  subtotal      Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("area_reservations")
}

model AddonReservation {
  id Int @id @default(autoincrement())

  reservationId Int
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  addonId Int
  addon   Addon @relation(fields: [addonId], references: [id], onDelete: Cascade)

  qty Int @default(1)

  priceSnapshot Decimal @db.Decimal(15, 2)
  subtotal      Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addon_reservations")
}

