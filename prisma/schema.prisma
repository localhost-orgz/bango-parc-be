generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
}

model User {
  id       Int    @id @default(autoincrement())
  fullName String
  email    String @unique

  password       String?
  whatsappNumber String
  role           UserRole @default(CUSTOMER)

  googleId     String? @unique
  googleAvatar String?
  googleToken  String?

  @@map("users")
}
